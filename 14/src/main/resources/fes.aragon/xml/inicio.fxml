<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="btnPrincipal" prefHeight="780.0" prefWidth="1120.0" style="-fx-background-color: #323543;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fes.aragon.controller.InicioController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1120.0" spacing="20.0" style="-fx-background-color: #0B0C0F;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Label prefHeight="32.0" prefWidth="552.0" text="PROYECTO COMPILADORES - INTERPRETE 20X20" textFill="#d6d8e1">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#mostrarInstrucciones" prefHeight="35.0" styleClass="alert-info" text="Ver Instrucciones" />
            </children>
        </HBox>
    </top>
    <left>
        <ToolBar orientation="VERTICAL" prefWidth="150.0" BorderPane.alignment="CENTER">
            <items>
                <Label alignment="CENTER" prefHeight="29.0" prefWidth="130.0" style="-fx-text-fill: #D6D8E1;" text="ARCHIVO" textAlignment="CENTER">
                    <font>
                        <Font size="20.0" />
                    </font>
                </Label>
                <Button fx:id="idAbrir" mnemonicParsing="false" onAction="#accionAbrirArchivo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-info" text="Abrir Archivo" />
                <Button fx:id="idCrearArchivo" mnemonicParsing="false" onAction="#crearArchivo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-info" text="Crear Archivo" />
                <Button fx:id="idGuardar" mnemonicParsing="false" onAction="#guardarEdicionArchivo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-success" text="Guardar Edicion" />
                <Button fx:id="idGuardarComo" mnemonicParsing="false" onAction="#guardarArchivoComo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-success" text="Guardar Como" />
                <Button fx:id="idLimpiar" mnemonicParsing="false" onAction="#limpiarAreaTexto" prefHeight="48.0" prefWidth="130.0" styleClass="alert-warning" text="Limpiar" />
                <Button fx:id="idQuitar" mnemonicParsing="false" onAction="#quitarArchivo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-warning" text="Quitar Archivo" />
                <Button fx:id="idEliminar" mnemonicParsing="false" onAction="#eliminarArchivo" prefHeight="48.0" prefWidth="130.0" styleClass="alert-danger" text="Eliminar" />
            </items>
        </ToolBar>
    </left>
    <center>
        <StackPane BorderPane.alignment="CENTER">
            <children>
                <Pane maxHeight="600.0" maxWidth="600.0" minHeight="600.0" minWidth="600.0" prefHeight="600.0" prefWidth="600.0" style="-fx-background-color: #FFFFFF;">
                    <children>
                        <Canvas fx:id="hoja" height="600.0" width="600.0" />
                        <ImageView fx:id="nave" fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" />
                    </children>
                </Pane>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </StackPane>
    </center>
    <right>
        <VBox prefWidth="320.0" spacing="10.0" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
            <children>
                <StackPane fx:id="contenedorEditor" prefHeight="400.0" style="-fx-background-color: #454A5E;" VBox.vgrow="ALWAYS" />
                <VBox prefHeight="127.0" prefWidth="320.0" spacing="5.0" style="-fx-background-color: #454A5E; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label style="-fx-text-fill: #D6D8E1; -fx-font-weight: bold;" text="Mini Debugger (Memoria)" />
                    <TableView fx:id="tablaDebugger" prefHeight="82.0" prefWidth="300.0" style="-fx-base: #323543; -fx-control-inner-background: #323543; -fx-text-fill: #F0F1F4;">
                        <columns>
                            <TableColumn fx:id="colVariable" prefWidth="145.0" text="Variable" />
                            <TableColumn fx:id="colValor" prefWidth="145.0" text="Valor" />
                        </columns>
                    </TableView>
                </VBox>
            </children>
        </VBox>
    </right>
    <bottom>
        <VBox minHeight="120.0" prefHeight="120.0" spacing="10.0" style="-fx-background-color: #0B0C0F;" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="lblEstado" prefHeight="18.0" prefWidth="897.0" style="-fx-text-fill: #D6D8E1;" text="Estado: Nuevo archivo sin título.">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label fx:id="consola" prefWidth="1080.0" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #D6D8E1;" text="Consola: Esperando ejecución..." />
                <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#ejecutarCodigo" prefHeight="35.0" prefWidth="120.0" styleClass="alert-success" text="EJECUTAR" />
                        <Button mnemonicParsing="false" onAction="#detenerAnimacion" prefHeight="35.0" prefWidth="120.0" styleClass="alert-danger" text="DETENER" />
                        <Button mnemonicParsing="false" onAction="#reiniciarNave" prefHeight="35.0" prefWidth="120.0" styleClass="alert-warning" text="REINICIAR" />
                        <ToggleButton fx:id="btnVelocidad" mnemonicParsing="false" onAction="#cambiarVelocidad" prefHeight="35.0" prefWidth="120.0" styleClass="alert-info" text="Velocidad: x1" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </bottom>
</BorderPane>
